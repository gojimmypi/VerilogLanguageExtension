<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <!-- IMPORTANT: tell VSSDK which manifest file to use (fixes VSSDK1039) -->
    <VsixManifest>source.extension.vsixmanifest</VsixManifest>
    <VisualStudioVersion Condition="'$(VisualStudioVersion)' == '' And Exists('$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v18.0\VSSDK\Microsoft.VsSDK.targets')">18.0</VisualStudioVersion>
    <VisualStudioVersion Condition="'$(VisualStudioVersion)' == '' And Exists('$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v17.0\VSSDK\Microsoft.VsSDK.targets')">17.0</VisualStudioVersion>
    <!-- Design-time builds sometimes fail the Exists() checks above; give it a sane default for IntelliSense -->
    <VisualStudioVersion Condition="'$(VisualStudioVersion)' == ''">17.0</VisualStudioVersion>
    <VSToolsPath Condition="'$(VSToolsPath)' == '' And '$(VisualStudioVersion)' != ''">$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)</VSToolsPath>
  </PropertyGroup>
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProductVersion>10.0.20305</ProductVersion>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <ProjectGuid>{F091221E-FD10-41A7-AAC4-C9359178BDB1}</ProjectGuid>
    <OutputType>Library</OutputType>
    <VsixType>v3</VsixType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>VerilogLanguage</RootNamespace>
    <AssemblyName>VerilogLanguage</AssemblyName>
    <!-- Modern VSSDK packages are happiest on net472 -->
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <TargetFrameworkIdentifier>.NETFramework</TargetFrameworkIdentifier>
    <FileAlignment>512</FileAlignment>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <PropertyGroup>
    <StartAction>Program</StartAction>
    <StartProgram>$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <VSCTCompile Include="VerilogLanguage.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>
  <!-- PackageReference MUST be before imports/targets -->
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.14.40265" PrivateAssets="all" />
    <PackageReference Include="Microsoft.VisualStudio.SDK.Analyzers" Version="17.7.79" PrivateAssets="all" />
    <PackageReference Include="Microsoft.VisualStudio.Threading.Analyzers" Version="17.14.15" PrivateAssets="all" />
    <!-- Removing this like technically works, but extends build time from 5 seconds to 50 seconds! TODO : why? -->
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.14.2120" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="System" />
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Core" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Web.Extensions" />
    <Reference Include="System.Xml" />
    <Reference Include="System.Xaml" />
    <Reference Include="WindowsBase" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Classification\ClassificationFormat.cs" />
    <Compile Include="Classification\ClassificationType.cs" />
    <Compile Include="Classification\VerilogClassifier.cs" />
    <Compile Include="CommentHelper\CommentHelper.cs" />
    <Compile Include="SnapshotExporter\GuidList.cs" />
    <Compile Include="SnapshotExporter\PkgCmdIDList.cs" />
    <Compile Include="SnapshotExporter\VerilogLanguagePackage.cs" />
    <Compile Include="SnapshotExporter\ExportSnapshotCommand.cs" />
    <Compile Include="SnapshotExporter\SnapshotExporter.cs" />
    <Compile Include="SnapshotExporter\SnapshotExportOnOpen.cs" />
    <Compile Include="SnapshotExporter\SnapshotModel.cs" />
    <Compile Include="Extensions\StringExtensions.cs" />
    <Compile Include="Globals\BufferAttributes.cs" />
    <Compile Include="Globals\OutputWindow.cs" />
    <Compile Include="Globals\Parsing.cs" />
    <Compile Include="Globals\PerfMon.cs" />
    <Compile Include="Globals\VerilogContext.cs" />
    <Compile Include="Globals\VerilogGlobals.cs" />
    <Compile Include="Globals\VerilogHelperFunctions.cs" />
    <Compile Include="Globals\VerilogParseState.cs" />
    <Compile Include="Globals\VerilogToken.cs" />
    <Compile Include="Highlighting\HighlightWordFormatDefinition.cs" />
    <Compile Include="Highlighting\HighlightWordTag.cs" />
    <Compile Include="Highlighting\HighlightWordTagger.cs" />
    <Compile Include="Highlighting\HighlightWordTaggerProvider.cs" />
    <Compile Include="Completion\CompletionController.cs" />
    <Compile Include="Completion\CompletionSource.cs" />
    <Compile Include="Intellisense\VerilogQuickInfoSource.cs" />
    <Compile Include="BraceMatching\BraceMatchingTagger.cs" />
    <Compile Include="BraceMatching\BraceMatchingTaggerProvider.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
    <Compile Include="Intellisense\QuickInfoController.cs" />
    <Compile Include="Intellisense\QuickInfoControllerProvider.cs" />
    <Compile Include="VerilogToken\VerilogTokenTag.cs" />
    <Compile Include="VerilogToken\VerilogTokenTypes.cs" />
    <Compile Include="VerilogToken\VerilogTokenTagger.cs" />
    <Compile Include="VerilogToken\VerilogTokenTagProvider.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include=".github\workflows\build-verilog-language-extension.yml" />
    <None Include="CODE_OF_CONDUCT.md" />
    <None Include="README.md" />
    <None Include="RELEASE_NOTES.md" />
    <None Include="Lattice_securelyfitz.md" />
    <None Include="source.extension.vsixmanifest" />
    <Content Include="LICENSE.md">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="ProjectTemplates\Verilog Project.zip">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="images\" />
    <Folder Include="Tagger\" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- Ensure we are not doing DLL-only builds
       IMPORTANT: do not hard-fail VSSDK imports during DesignTimeBuild, or IntelliSense loses Microsoft.VisualStudio.Text types -->
  <Target Name="FailIfVsSdkMissing" BeforeTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <Error Condition="'$(VSToolsPath)' == '' Or !Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" Text="Missing Microsoft.VsSDK.targets. Build from a VS developer prompt or set VisualStudioVersion/VSToolsPath." />
  </Target>
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />
</Project>